# =============================================================================
# grocery-app environment variables
# -----------------------------------------------------------------------------
# HOW TO USE:
#   1. Copy this file to ".env.local"  ->  cp .env.example .env.local
#   2. Fill in the values as you reach each phase (see notes below).
#   3. NEVER commit ".env.local" or any real keys. Only this example file is
#      committed to git.
#
# WHICH VARS DO I NEED RIGHT NOW?
#   - Phase 1 (scaffold): NONE. The app runs with no keys at all.
#   - Phase 2 (database): the SUPABASE_* vars.
#   - Phase 5 (auth):     the SUPABASE_* vars + Google OAuth (configured in
#                         the Supabase dashboard, not here).
#   - Phase 6 (payments): the STRIPE_* vars.
#   - Optional:           the geocoding vars (defaults to a free mock).
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. Everything
# else is server-only and must never be sent to the client.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase  (Phase 2+)
#   Get these from the green "Connect" button in your project dashboard, or
#   under Project Settings > API Keys.
# -----------------------------------------------------------------------------
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The PUBLISHABLE key (starts with "sb_publishable_"). This is the public,
# browser-safe key. Your data is protected by Row-Level Security, not by hiding
# this key. (On older projects this was called the "anon" key.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The SECRET key (starts with "sb_secret_"). FULL ADMIN ACCESS — bypasses
# Row-Level Security. Server-side ONLY (ingestion jobs, admin actions). Never
# expose to the browser or commit it. (On older projects this was the
# "service_role" key.) Not needed until Phase 3.
SUPABASE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Ingestion  (Phase 3)
# -----------------------------------------------------------------------------
# A shared secret that protects the POST /api/ingest endpoint (the price-refresh
# job). Pick any long random string. The scheduler (e.g. Vercel Cron) and any
# manual trigger must send it. Server-only — never expose to the browser.
INGEST_SECRET=


# -----------------------------------------------------------------------------
# Stripe  (Phase 6)   ->  https://dashboard.stripe.com/test/apikeys
# -----------------------------------------------------------------------------
# Use TEST mode keys while developing (they start with sk_test_ / pk_test_).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# The Price ID for the $5.99 CAD/month subscription (create a recurring CAD
# price in the Stripe dashboard, then paste its id here, e.g. price_123...).
STRIPE_PRICE_ID_MONTHLY=

# Webhook signing secret (from `stripe listen` locally, or the dashboard in prod).
# Used to verify incoming webhook events are really from Stripe.
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Geocoding / distance  (optional — defaults to a free built-in mock)
# -----------------------------------------------------------------------------
# Which provider the pluggable geocoder uses. Options: "mock" | "google" | "mapbox".
# Leave as "mock" to run with zero paid keys.
GEOCODER_PROVIDER=mock

# Only needed if GEOCODER_PROVIDER=google
GOOGLE_MAPS_API_KEY=

# Only needed if GEOCODER_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
# The public base URL of the app. Used for OAuth redirects and Stripe return URLs.
# Local default below; set to your real domain in production (e.g. https://app.example.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Free tier: how many searches a non-subscriber gets per month before being
# prompted to upgrade. Single source of truth — change here, not in code.
NEXT_PUBLIC_FREE_SEARCH_LIMIT=5

# Default market/currency. Built to be extended to other regions later.
NEXT_PUBLIC_DEFAULT_CURRENCY=CAD
NEXT_PUBLIC_DEFAULT_REGION=ON
